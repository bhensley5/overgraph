    "S-TRAV-001": {
      "status": "comparable"
    },
    "S-TRAV-002": {
      "status": "comparable"
    },
    "S-ADV-001": {
      "status": "comparable"
    },
    "S-ADV-003": {
      "status": "comparable"
    },
    "S-ADV-004": {
      "status": "comparable"
    },
    "S-CRUD-004": {
      "status": "comparable"
    },
    "S-CRUD-005": {
      "status": "comparable"
    },
    "S-ADV-005": {
      "status": "comparable"
    },
    "S-MAIN-001": {
      "status": "comparable"
    }
  },
  "percentile_method": {
    "name": "nearest_rank",
    "index_formula": "ceil((p / 100) * n) - 1",
    "interpolation": "none",
    "sorted_order": "ascending",
    "sample_unit": "microseconds"
  }
