    "S-BATCH-002": {
      "warmup_divisor": 2,
      "warmup_min": 5,
      "iters_divisor": 2,
      "iters_min": 20
    },
    "S-ADV-004": {
      "warmup_divisor": 2,
      "warmup_min": 5,
      "iters_divisor": 2,
      "iters_min": 20
    },
    "S-ADV-005": {
      "warmup_divisor": 2,
      "warmup_min": 5,
      "iters_divisor": 2,
      "iters_min": 20
    },
    "S-MAIN-001": {
      "warmup_divisor": 3,
      "warmup_min": 3,
      "iters_divisor": 4,
      "iters_min": 10
    },
    "S-CRUD-001": {},
    "S-CRUD-002": {},
    "S-CRUD-003": {}
  },
  "comparability": {
    "S-CRUD-001": {
      "status": "comparable"
    },
    "S-CRUD-002": {
      "status": "comparable"
    },
    "S-CRUD-003": {
      "status": "comparable"
    },
    "S-BATCH-001": {
      "status": "comparable"
    },
    "S-BATCH-002": {
      "status": "non_comparable",
