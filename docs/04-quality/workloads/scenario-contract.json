{
  "schema_version": 1,
  "description": "Cross-language benchmark scenario contract for parity validation.",
  "effective_config": {
    "nodes_divisor": 50,
    "nodes_min": 1000,
    "edges_divisor": 50,
    "edges_min": 5000,
    "fanout_min": 25,
    "fanout_max": 500,
    "fanout_degree_multiplier": 20,
    "batch_nodes_min": 50,
    "batch_edges_min": 50,
    "two_hop_mid_min": 50,
    "two_hop_leaves_per_mid": 8,
    "top_k_candidates_min": 500,
    "top_k_candidates_divisor": 2,
    "ppr_nodes_min": 500,
    "ppr_nodes_divisor": 2,
    "time_range_nodes_cap": 5000,
    "export_nodes_cap": 5000,
    "export_edges_cap": 20000,
    "flush_node_batch_cap": 200,
    "flush_edge_chain_cap": 50,
    "ppr_max_iterations": 20,
    "ppr_max_results": 50,
    "ppr_seed_count": 1,
    "ppr_edge_offsets": [1, 7],
    "top_k_limit": 20,
    "time_range_from_ms": 0,
    "time_range_window_ms": 60000,
    "include_weights_on_export": true
